{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://refactor-report-schemas.cerberauth-schemas.pages.dev/vulnapi/draft/2024-10/security-scheme-report.schema.json",
    "title": "Operation Security Scheme Report",
    "description": "",
    "type": "object",
    "required": [
        "type",
        "scheme",
        "name"
    ],
    "properties": {
        "type": {
            "type": "string",
            "enum": [
                "apiKey",
                "http",
                "oauth2",
                "openIdConnect",
                "none"
            ]
        },
        "scheme": {
            "type": "string",
            "enum": [
                "basic",
                "bearer",
                "digest",
                "oauth",
                "privateToken",
                "none"
            ]
        },
        "in": {
            "type": "string",
            "enum": [
                "header",
                "cookie"
            ]
        },
        "name": {
            "type": "string"
        }
    }
}